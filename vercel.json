{
    "rewrites": [
        {
            "source": "/maps-api/:path*",
            "destination": "https://maps.googleapis.com/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}