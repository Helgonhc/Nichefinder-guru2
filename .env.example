# Variáveis de Ambiente — LeadRadar Guru
# Copie este arquivo para .env e preencha os valores
# IMPORTANTE: Nunca commite o arquivo .env no git!

# ============================================
# SUPABASE (obrigatório)
# ============================================
# URL do seu projeto Supabase (ex: https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=

# Chave ANON/Publishable do Supabase (segura para expor no frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=

# ============================================
# CONFIGURAÇÕES DO SERVIDOR (server/pdf-engine.js)
# ============================================
# Porta do servidor de PDFs (padrão: 3001)
PORT=3001

# ============================================
# APIs EXTERNAS (configuradas no Supabase Edge Functions)
# ============================================
# Estas chaves NÃO devem ir para o frontend.
# Configure-as como Secrets no painel do Supabase:
# https://supabase.com/dashboard/project/_/settings/secrets
#
# GROQ_API_KEY=         → IA para geração de scripts
# GOOGLE_PLACES_API_KEY= → Google Places para busca de leads
# SERPER_API_KEY=       → Serper.dev para busca web
# SUPABASE_SERVICE_ROLE_KEY= → Admin key (apenas servidor)
